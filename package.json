{
  "name": "free-api-switch",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/tray/main.js",
  "bin": {
    "fas": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "test": "tsx --test",
    "check": "tsc --noEmit -p tsconfig.json",
    "tray:dev": "npm run build && electron .",
    "tray:dist": "npm run build && electron-builder --win --config electron-builder.json --publish never && node scripts/prepare_release_cfgs.mjs"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "electron": "^32.3.3",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^5.5.0"
  },
  "config": {
    "electron_builder_binaries_mirror": "https://npmmirror.com/mirrors/electron-builder-binaries/"
  }
}
